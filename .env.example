# Kopieer naar .env en vul in. Nooit .env committen (staat in .gitignore).

# Claude API
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=                 # https://<project>.supabase.co
SUPABASE_ANON_KEY=            # Publieke sleutel (alleen client-side, niet gebruikt door deze pipeline)
SUPABASE_SERVICE_KEY=         # Service role (server-side only, bypasses RLS)

# E-mail bezorging
RESEND_API_KEY=
FROM_EMAIL=digest@kansenradar.be

# e-Procurement (fase 2b, e_notification scraper)
E_NOTIFICATION_API_KEY=

# Digest-instellingen
DIGEST_SEND_TIME=07:00
MAX_TENDERS_PER_DIGEST=5
MIN_RELEVANCE_SCORE=6
